SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FRONTEND_URL=https://webrief.app
CORS_ORIGINS=https://webrief.app
RATE_LIMIT_STORE=memory
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
# Leave empty in Prod (or set to "prod/" if you want an explicit prefix). When
# empty, uploads keep the same paths they had before Dev/Prod separation.
IMAGEKIT_FOLDER_PREFIX=
# Defaults to enabled when unset. Keep unset (or "true") in Prod.
EMAIL_ENABLED=true
PORT=3000
