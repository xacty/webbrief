SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_STORE=memory
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
# Optional folder prefix for environment isolation. Set to e.g. "dev/" in local
# dev so uploads land under /dev/... in ImageKit and don't mix with Prod paths.
# Leave empty in Prod (or set to "prod/" for explicit clarity).
IMAGEKIT_FOLDER_PREFIX=dev/
# Set to "false" to skip outbound emails (logged instead). Use in local dev to
# avoid spamming real users while testing. Defaults to enabled.
EMAIL_ENABLED=false
PORT=3000
